<style>
  .shopify-block {
    display: contents;
  }

  .custom-icon-box {
    display: flex;
    justify-content: space-between;
    padding-top: 48px;
    padding-left:0px;
    padding-right:0px;
    align-items: center;
    gap: 35%;
  }
  .custom-icon-box:not(:last-child) {
    border-bottom: 1px solid #d1d0cc;
    padding-bottom: 48px;
  }
  .custom-icon-box-numbers {
    font-size: 14px;
    font-weight: 600;
    color: #888682;
  }
  .custom-icon-box-heading {
    font-size: 24px;
    font-weight: 600;
    color: #000;
    margin: 0;
  }
  .custom-icon-box-content {
    display: flex;
    gap: 20px;
  }
  .custom-icon-box-text {
    font-size: 16px;
    color: #888682;
  }
  .custom-icon-box-icon {
    min-width: 40px;
  }

  @media screen and (max-width:600px){
    .custom-icon-box-icon{
      display:none;
    }
      .custom-icon-box {
    padding: 20px 0;
  }
  }
</style>

<section style="width:100%">
  <div class="custom-icon-box">
    <div class="custom-icon-box-content">
      <p class="custom-icon-box-numbers">01</p>
      <div>
        <h4 class="custom-icon-box-heading">48 Hour Delivery</h4>
        <p class="custom-icon-box-text">
          Don't let empty shelves slow down your operations. Your parcel will be delivered straight to your door within
          48 hours of placing your order.
        </p>
      </div>
    </div>
    <div class="custom-icon-box-icon">
      <svg width="46" height="37" viewBox="0 0 13 11" fill="none" xmlns="http://www.w3.org/2000/svg">
