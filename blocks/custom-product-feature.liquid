<style>
    .shopify-block{
        display: contents !important;
    }

.section-heading{
    text-align:center;
    margin-bottom:60px;
}


.features-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    gap:30px;
}

.feature-card h5{
    margin:14px 0 0 !important;
}

.feature-card p{
    margin:6px 0 0 !important;
}

.feature-card{
    background:#fff;
    border: 1px solid #F0F0F0;
    padding:24px;
}


</style>

{% schema %}
{
  "name": "Why Choose Us",
  "tag": "section",
  "class": "why-choose-us-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Customers Choose Us"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Sub Heading",
      "default": "Premium products backed by fast delivery, transparent pricing and trusted customer service."
    }
  ],
  "presets": [
    {
      "name": "Why Choose Us"
    }
  ]
}
{% endschema %}